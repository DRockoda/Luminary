# ─── Database (Supabase) ──────────────────────────────────────────────────────
# Get both URLs from: supabase.com → your project → Connect → ORM → Prisma
# Replace [YOUR-PASSWORD] with your Supabase database password (URL-encode if it
# contains @, :, /, #, etc.)

# Supabase connection pooler (port 6543) — for all normal queries
DATABASE_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase direct connection (port 5432) — for migrations only
DIRECT_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres"

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=generate_a_long_random_string_here
JWT_REFRESH_SECRET=generate_a_different_long_random_string_here
ADMIN_JWT_SECRET=generate_another_long_random_string_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
ADMIN_JWT_EXPIRES_IN=8h

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
# Local: localhost. On Vercel, leave unset (host-only cookies) unless you use a shared parent domain.
COOKIE_DOMAIN=localhost
# For Netlify (SPA) + Vercel (API) on different hosts, set: COOKIE_SAMESITE=none
COOKIE_SAMESITE=strict
# On Vercel serverless, use a writable path (e.g. /tmp/uploads)
UPLOAD_DIR=./uploads

# ─── Email (Brevo) ────────────────────────────────────────────────────────────
BREVO_API_KEY=
EMAIL_FROM=Luminary <your-verified-sender@example.com>

# ─── Google Drive OAuth ───────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/drive/callback

# ─── Encryption ───────────────────────────────────────────────────────────────
ENCRYPTION_SERVER_KEY=your_64_character_hex_string_here
