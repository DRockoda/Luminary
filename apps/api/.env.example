# ─── Database ─────────────────────────────────────────────────────────────────
# Default for this repo: SQLite (see apps/api/prisma/schema.prisma)
DATABASE_URL=file:./dev.db
# If you switch Prisma to PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/luminary

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=generate_a_long_random_string_here
JWT_REFRESH_SECRET=generate_a_different_long_random_string_here
ADMIN_JWT_SECRET=generate_another_long_random_string_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
ADMIN_JWT_EXPIRES_IN=8h

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
COOKIE_DOMAIN=localhost
UPLOAD_DIR=./uploads

# ─── Email (Brevo — used by the API) ─────────────────────────────────────────
# Sign up at https://www.brevo.com — leave empty in dev to log emails to the console
BREVO_API_KEY=
EMAIL_FROM=Luminary <your-verified-sender@example.com>

# Optional — Resend is not wired in this codebase; use BREVO_API_KEY above.
# RESEND_API_KEY=re_your_key_here

# ─── Google Drive OAuth ───────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/drive/callback

# ─── Encryption ───────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_SERVER_KEY=your_64_character_hex_string_here
