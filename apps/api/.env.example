# ─── Database (PostgreSQL — Supabase or local Docker) ─────────────────────────
# Supabase: Project Settings → Database → copy "Transaction pooler" (6543) and
# "Session" or direct (5432). For local Docker without PgBouncer, use the same URL twice.
DATABASE_URL=postgresql://luminary:luminary@localhost:5432/luminary
DIRECT_URL=postgresql://luminary:luminary@localhost:5432/luminary

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=generate_a_long_random_string_here
JWT_REFRESH_SECRET=generate_a_different_long_random_string_here
ADMIN_JWT_SECRET=generate_another_long_random_string_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
ADMIN_JWT_EXPIRES_IN=8h

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
COOKIE_DOMAIN=localhost
# For Netlify (SPA) + Vercel (API) on different hosts, set: COOKIE_SAMESITE=none
COOKIE_SAMESITE=strict
# On Vercel serverless, use a writable path (e.g. /tmp/uploads)
UPLOAD_DIR=./uploads

# ─── Email (Brevo) ────────────────────────────────────────────────────────────
BREVO_API_KEY=
EMAIL_FROM=Luminary <your-verified-sender@example.com>

# ─── Google Drive OAuth ───────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/drive/callback

# ─── Encryption ───────────────────────────────────────────────────────────────
ENCRYPTION_SERVER_KEY=your_64_character_hex_string_here
