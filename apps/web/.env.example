# ─── API ──────────────────────────────────────────────────────────────────────
# Leave unset (or empty) for local dev — the browser calls /api on :5173 and
# Vite proxies to the API (see vite.config.ts). Avoid http://localhost:3000 here
# or you'll hit cross-origin + cookie issues (often "Network Error" in Axios).
#
# Optional: if your API runs on a non-default host/port, set only for the proxy:
# VITE_DEV_API_PROXY=http://127.0.0.1:3001
#
# Production (Netlify etc.): full HTTPS origin of your deployed API, no trailing slash.
# VITE_API_URL=https://your-api.vercel.app

# ─── App ──────────────────────────────────────────────────────────────────────
VITE_APP_NAME=Luminary
VITE_APP_VERSION=0.1.0
